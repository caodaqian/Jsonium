{
  "$schema": "https://raw.githubusercontent.com/uTools-Labs/utools-api-types/refs/heads/main/resource/utools.schema.json",
  "main": "index.html",
  "preload": "preload/services.js",
  "logo": "logo.png",
  "development": {
    "main": "http://localhost:4000/index.html"
  },
  "features": [
    {
      "code": "process",
      "explain": "Jsonium",
      "cmds": [
        "json",
        {
          "type": "regex",
          "label": "Json",
          "match": "/^\\s*(\\{[\\s\\S]*\\}|\\[[\\s\\S]*\\])\\s*$/",
          "minLength": 20
        },
        {
          "type": "regex",
          "label": "QuotedJson",
          "match": "/^(['\"`][\\s\\S+]+['\"`])$/",
          "minLength": 20
        },
        {
          "type": "regex",
          "label": "Base64Json",
          "match": "/^(?:[A-Za-z0-9+/][A-Za-z0-9+/][A-Za-z0-9+/][A-Za-z0-9+/])+(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$/",
          "minLength": 20
        },
        {
          "type": "files",
          "fileType": "file",
          "maxLength": 1,
          "label": "从文件中读取 JSON"
        }
      ]
    }
  ]
}